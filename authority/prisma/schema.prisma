

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  department_id      BigInt    @id @default(autoincrement()) @map("department_id")
  department_code    String?
  department_name    String?
  department_head_id BigInt?   @unique
  office_location    String?
  contact_email      String?
  contact_phone      String?
  established_year   Int?
  status             String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  department_head    Teacher?  @relation("DepartmentHead", fields: [department_head_id], references: [teacher_id])
  teachers           Teacher[] @relation("TeacherDepartment")
  programs           Program[]

  @@unique([department_code])
  @@map("departments")
}

model Classroom {
  classroom_id          BigInt              @id @default(autoincrement()) @map("classroom_id")
  room_number           String?             @unique
  building_name         String?
  floor_number          Int?
  seating_capacity      Int?

  projector_available   Boolean?
  smart_board_available Boolean?
  status                String?
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt
  sections              Section[]
  timetables            Timetable[]
  attendance_sessions   AttendanceSession[]

  @@map("classrooms")
}

model TimeSlot {
  time_slot_id     BigInt      @id @default(autoincrement()) @map("time_slot_id")
  slot_name        String      @unique
  start_time       DateTime?   @db.Time
  end_time         DateTime?   @db.Time
  duration_minutes Int?
  is_break         Boolean?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt
  timetables       Timetable[]

  @@map("time_slots")
}

model Subject {
  subject_id           BigInt                     @id @default(autoincrement()) @map("subject_id")
  subject_code         String?
  subject_name         String?
  program_id           BigInt
  semester_number      Int?
  subject_order        Int?
  subject_category     String?
  credits              Int?
  subject_type         String?
  lecture_hours        Int?
  tutorial_hours       Int?
  practical_hours      Int?
  syllabus_version     String?
  description          String?                    @db.Text
  created_at           DateTime                   @default(now())
  updated_at           DateTime                   @updatedAt
  program              Program                    @relation(fields: [program_id], references: [program_id])
  teacher_assignments  TeacherSubjectAssignment[]
  timetables           Timetable[]
  attendance_sessions  AttendanceSession[]
  attendance_summaries AttendanceSummary[]
  backlogs             StudentBacklog[]
  enrollments          SubjectEnrollment[]
  exams                Exam[]
  modules              SyllabusModule[]

  @@unique([subject_code])
  @@index([program_id])
  @@index([program_id, semester_number])
  @@map("subjects")
}

model Teacher {
  teacher_id           BigInt                     @id @default(autoincrement()) @map("teacher_id")
  user_id              BigInt?                    @unique @map("user_id")
  employee_id          String?
  first_name           String?
  last_name            String?
  gender               String?
  date_of_birth        DateTime?                  @db.Date
  department_id        BigInt
  designation          String?
  qualification        String?
  specialization       String?
  joining_date         DateTime?                  @db.Date
  experience_years     Int?
  phone_number         String?
  office_room          String?
  employment_type      String?
  salary_grade         String?
  status               String?
  created_at           DateTime                   @default(now())
  updated_at           DateTime                   @updatedAt
  user                 User?                      @relation(fields: [user_id], references: [user_id])
  department           Department                 @relation("TeacherDepartment", fields: [department_id], references: [department_id])
  department_headed    Department?                @relation("DepartmentHead")
  coordinated_programs Program[]                  @relation("ProgramCoordinator")
  subject_assignments  TeacherSubjectAssignment[]
  timetables           Timetable[]
  attendance_sessions  AttendanceSession[]
  topic_coverage       TopicCoverage[]

  @@unique([employee_id])
  @@index([department_id])
  @@index([status])
  @@map("teachers")
}

model Program {
  program_id             BigInt                   @id @default(autoincrement()) @map("program_id")
  department_id          BigInt
  program_code           String?
  program_name           String?
  degree_type            String?
  program_duration_years Int?
  total_semesters        Int?
  description            String?                  @db.Text
  accreditation_body     String?
  program_coordinator_id BigInt?
  status                 String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt
  department             Department               @relation(fields: [department_id], references: [department_id])
  coordinator            Teacher?                 @relation("ProgramCoordinator", fields: [program_coordinator_id], references: [teacher_id])
  batches                Batch[]
  students               Student[]
  subjects               Subject[]

  @@unique([program_code])
  @@index([department_id])
  @@index([program_coordinator_id])
  @@index([status])
  @@map("programs")
}

model Batch {
  batch_id                 BigInt                     @id @default(autoincrement()) @map("batch_id")
  program_id               BigInt
  admission_year           Int?
  expected_graduation_year Int?
  batch_name               String?
  period_id                BigInt?
  total_students           Int?
  status                   String?
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @updatedAt
  program                  Program                    @relation(fields: [program_id], references: [program_id])
  academic_period          AcademicPeriod?            @relation(fields: [period_id], references: [period_id])
  sections                 Section[]
  students                 Student[]
  teacher_assignments      TeacherSubjectAssignment[]
  timetables               Timetable[]
  attendance_sessions      AttendanceSession[]
  exams                    Exam[]
  batch_semesters          BatchSemester[]
  topic_coverage           TopicCoverage[]

  @@index([program_id])
  @@index([admission_year])
  @@index([status])
  @@map("batches")
}

model Section {
  section_id          BigInt                     @id @default(autoincrement()) @map("section_id")
  batch_id            BigInt
  section_name        String?
  classroom_id        BigInt?
  section_strength    Int?
  floor_number        Int?
  building_name       String?
  status              String?
  created_at          DateTime                   @default(now())
  updated_at          DateTime                   @updatedAt
  batch               Batch                      @relation(fields: [batch_id], references: [batch_id])
  classroom           Classroom?                 @relation(fields: [classroom_id], references: [classroom_id])
  students            Student[]
  teacher_assignments TeacherSubjectAssignment[]
  timetables          Timetable[]
  attendance_sessions AttendanceSession[]
  topic_coverage      TopicCoverage[]

  @@index([batch_id])
  @@index([classroom_id])
  @@map("sections")
}

model Student {
  student_id             BigInt              @id @default(autoincrement()) @map("student_id")
  user_id                BigInt?             @unique @map("user_id")
  university_roll_number String?
  registration_number    String?
  first_name             String?
  last_name              String?
  gender                 String?
  date_of_birth          DateTime?           @db.Date
  batch_id               BigInt
  section_id             BigInt
  program_id             BigInt
  admission_date         DateTime?           @db.Date
  student_status         String?
  has_backlogs           Boolean             @default(false)
  phone_number           String?
  address                String?
  city                   String?
  state                  String?
  country                String?
  postal_code            String?
  blood_group            String?
  nationality            String?
  category               String?
  created_at             DateTime            @default(now())
  updated_at             DateTime            @updatedAt
  user                   User?               @relation(fields: [user_id], references: [user_id])
  batch                  Batch               @relation(fields: [batch_id], references: [batch_id])
  section                Section             @relation(fields: [section_id], references: [section_id])
  program                Program             @relation(fields: [program_id], references: [program_id])
  guardian               Guardian?
  face_data              FaceData[]
  attendance_records     AttendanceRecord[]
  attendance_summaries   AttendanceSummary[]
  backlogs               StudentBacklog[]
  enrollments            SubjectEnrollment[]
  exam_results           ExamResult[]
  practice_results       ModulePracticeResult[]

  @@unique([university_roll_number])
  @@unique([registration_number])
  @@index([batch_id])
  @@index([section_id])
  @@index([program_id])
  @@index([student_status])
  @@index([has_backlogs])
  @@map("students")
}

model Guardian {
  guardian_id     BigInt   @id @default(autoincrement()) @map("guardian_id")
  student_id      BigInt   @unique
  father_name     String?
  mother_name     String?
  guardian_name   String?
  relation_type   String?
  phone_number    String?
  alternate_phone String?
  email           String?
  occupation      String?
  address         String?
  city            String?
  state           String?
  postal_code     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  student         Student  @relation(fields: [student_id], references: [student_id])

  @@map("guardians")
}

model StudentBacklog {
  backlog_id          BigInt   @id @default(autoincrement()) @map("backlog_id")
  student_id          BigInt
  subject_id          BigInt
  semester_number     Int
  attempt_number      Int      @default(1)
  status              String   @default("PENDING")
  cleared_in_semester Int?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  student             Student  @relation(fields: [student_id], references: [student_id])
  subject             Subject  @relation(fields: [subject_id], references: [subject_id])

  @@unique([student_id, subject_id, attempt_number])
  @@index([student_id, status])
  @@index([subject_id])
  @@map("student_backlogs")
}

model SubjectEnrollment {
  enrollment_id   BigInt          @id @default(autoincrement()) @map("enrollment_id")
  student_id      BigInt
  subject_id      BigInt
  period_id       BigInt
  status          String?         @default("ACTIVE") // ACTIVE, DROPPED, COMPLETED
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  student         Student         @relation(fields: [student_id], references: [student_id])
  subject         Subject         @relation(fields: [subject_id], references: [subject_id])
  period          AcademicPeriod  @relation(fields: [period_id], references: [period_id])

  @@unique([student_id, subject_id, period_id])
  @@index([student_id, period_id])
  @@index([subject_id])
  @@map("subject_enrollments")
}

model Exam {
  exam_id         BigInt             @id @default(autoincrement()) @map("exam_id")
  subject_id      BigInt
  batch_id        BigInt
  period_id       BigInt
  exam_type       String       // INTERNAL_1, INTERNAL_2, MID_TERM, END_TERM
  total_marks     Float
  passing_marks   Float
  exam_date       DateTime?
  status          String?      @default("HIDDEN") // HIDDEN, OPEN, CLOSED, DECLARED
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  subject         Subject      @relation(fields: [subject_id], references: [subject_id])
  batch           Batch        @relation(fields: [batch_id], references: [batch_id])
  period          AcademicPeriod @relation(fields: [period_id], references: [period_id])
  results         ExamResult[]

  @@index([subject_id, batch_id])
  @@map("exams")
}

model ExamResult {
  result_id      BigInt   @id @default(autoincrement()) @map("result_id")
  exam_id        BigInt
  student_id     BigInt
  marks_obtained Float?
  is_absent      Boolean  @default(false)
  is_pass        Boolean?
  remarks        String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  exam           Exam     @relation(fields: [exam_id], references: [exam_id])
  student        Student  @relation(fields: [student_id], references: [student_id])

  @@unique([exam_id, student_id])
  @@index([student_id])
  @@map("exam_results")
}

model TeacherSubjectAssignment {
  assignment_id           BigInt          @id @default(autoincrement()) @map("assignment_id")
  teacher_id              BigInt
  subject_id              BigInt
  batch_id                BigInt
  section_id              BigInt
  period_id               BigInt
  assigned_hours_per_week Int?
  assignment_role         String?
  assignment_status       String?         @default("ACTIVE") // ACTIVE, COMPLETED, REVOKED
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt
  teacher                 Teacher         @relation(fields: [teacher_id], references: [teacher_id])
  subject                 Subject         @relation(fields: [subject_id], references: [subject_id])
  batch                   Batch           @relation(fields: [batch_id], references: [batch_id])
  section                 Section         @relation(fields: [section_id], references: [section_id])
  period                  AcademicPeriod  @relation(fields: [period_id], references: [period_id])

  @@unique([teacher_id, subject_id, batch_id, section_id, period_id])
  @@index([teacher_id, period_id])
  @@index([subject_id, period_id])
  @@index([batch_id, section_id, period_id])
  @@map("teacher_subject_assignments")
}

model Timetable {
  timetable_id        BigInt              @id @default(autoincrement()) @map("timetable_id")
  teacher_id          BigInt
  subject_id          BigInt
  batch_id            BigInt
  section_id          BigInt
  classroom_id        BigInt
  period_id           BigInt
  day_of_week         String
  time_slot_id        BigInt
  timetable_status    String?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  teacher             Teacher             @relation(fields: [teacher_id], references: [teacher_id])
  subject             Subject             @relation(fields: [subject_id], references: [subject_id])
  batch               Batch               @relation(fields: [batch_id], references: [batch_id])
  section             Section             @relation(fields: [section_id], references: [section_id])
  classroom           Classroom           @relation(fields: [classroom_id], references: [classroom_id])
  time_slot           TimeSlot            @relation(fields: [time_slot_id], references: [time_slot_id])
  period              AcademicPeriod      @relation(fields: [period_id], references: [period_id])
  attendance_sessions AttendanceSession[]

  @@unique([section_id, day_of_week, time_slot_id, period_id])
  @@unique([teacher_id, day_of_week, time_slot_id, period_id])
  @@unique([classroom_id, day_of_week, time_slot_id, period_id])
  @@index([section_id, period_id])
  @@index([subject_id, period_id])
  @@index([batch_id, period_id])
  @@index([teacher_id, period_id])
  @@map("timetables")
}

model FaceData {
  face_id             BigInt    @id @default(autoincrement()) @map("face_id")
  student_id          BigInt
  image_path          String?
  face_encoding       String?   @db.Text
  dataset_version     String?
  capture_date        DateTime? @db.Date
  image_quality_score Float?
  status              String?
  model_name          String?
  face_angle          String?   // e.g. "Front", "Left", "Right"
  is_primary          Boolean   @default(true)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  student             Student   @relation(fields: [student_id], references: [student_id])

  @@index([student_id])
  @@index([status])
  @@map("face_data")
}

model AttendanceSession {
  session_id         BigInt             @id @default(autoincrement()) @map("session_id")
  timetable_id       BigInt
  teacher_id         BigInt
  subject_id         BigInt
  batch_id           BigInt
  section_id         BigInt
  classroom_id       BigInt
  session_date       DateTime?          @db.Date
  start_time         DateTime?          @db.Time
  end_time           DateTime?          @db.Time
  attendance_method  String?
  total_students     Int?
  present_count      Int?
  absent_count       Int?
  class_photo_url    String?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  timetable          Timetable          @relation(fields: [timetable_id], references: [timetable_id])
  teacher            Teacher            @relation(fields: [teacher_id], references: [teacher_id])
  subject            Subject            @relation(fields: [subject_id], references: [subject_id])
  batch              Batch              @relation(fields: [batch_id], references: [batch_id])
  section            Section            @relation(fields: [section_id], references: [section_id])
  classroom          Classroom          @relation(fields: [classroom_id], references: [classroom_id])
  attendance_records AttendanceRecord[]
  covered_topics     TopicCoverage[]

  @@unique([timetable_id, session_date])
  @@index([session_date])
  @@index([subject_id, session_date])
  @@index([batch_id, section_id, subject_id])
  @@index([teacher_id, session_date])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  attendance_id        BigInt            @id @default(autoincrement()) @map("attendance_id")
  session_id           BigInt
  student_id           BigInt
  attendance_status    String?
  detection_confidence Float?
  capture_time         DateTime?
  marked_by            String?
  remarks              String?
  captured_face_url    String?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  session              AttendanceSession @relation(fields: [session_id], references: [session_id])
  student              Student           @relation(fields: [student_id], references: [student_id])

  @@unique([session_id, student_id])
  @@index([student_id, attendance_status])
  @@index([session_id])
  @@map("attendance_records")
}

model AttendanceSummary {
  summary_id            BigInt          @id @default(autoincrement()) @map("summary_id")
  student_id            BigInt
  subject_id            BigInt
  period_id             BigInt
  total_classes         Int?
  classes_attended      Int?
  classes_missed        Int?
  attendance_percentage Float?
  last_updated          DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  student               Student         @relation(fields: [student_id], references: [student_id])
  subject               Subject         @relation(fields: [subject_id], references: [subject_id])
  period                AcademicPeriod  @relation(fields: [period_id], references: [period_id])

  @@unique([student_id, subject_id, period_id])
  @@index([student_id, period_id])
  @@index([subject_id, period_id])
  @@index([attendance_percentage])
  @@map("attendance_summary")
}

model LibraryVisitLog {
  library_log_id       BigInt    @id @default(autoincrement()) @map("library_log_id")
  user_id              BigInt    @map("user_id")

  library_entry_at     DateTime  @map("library_entry_at")
  library_exit_at      DateTime? @map("library_exit_at")

  // States: 'ACTIVE' (user inside) | 'CLOSED' (exited) | 'AUTO_CLOSED' (force-closed at night)
  library_session_state String   @default("ACTIVE") @map("library_session_state")

  library_created_on   DateTime  @default(now()) @map("library_created_on")
  library_updated_on   DateTime  @updatedAt @map("library_updated_on")
  
  user                 User      @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@index([library_session_state])
  @@index([library_entry_at])
  @@map("library_visit_logs")
}

model User {
  user_id       BigInt    @id @default(autoincrement()) @map("user_id")
  email         String    @unique
  password_hash String?
  role          String    @default("STUDENT") // STUDENT, TEACHER, ADMIN
  is_active     Boolean   @default(true)
  profile_image_url String?
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  student            Student?
  teacher            Teacher?
  admin              Admin?
  library_visit_logs LibraryVisitLog[]

  @@map("users")
}

model Admin {
  admin_id      BigInt    @id @default(autoincrement()) @map("admin_id")
  user_id       BigInt    @unique @map("user_id")
  
  employee_id   String?   @unique @map("employee_id")
  first_name    String?
  last_name     String?
  phone_number  String?
  designation   String?   // e.g., "Registrar", "IT Administrator"
  
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  
  user          User      @relation(fields: [user_id], references: [user_id])

  @@map("admins")
}

model AcademicPeriod {
  period_id       BigInt             @id @default(autoincrement()) @map("period_id")
  name            String             // e.g., "Aug-Dec 2024"
  academic_year   String             // e.g., "2024-25"
  term_type       String?            // e.g., "ODD", "EVEN"
  is_active       Boolean            @default(false)
  start_date      DateTime?
  end_date        DateTime?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  batches         Batch[]
  enrollments     SubjectEnrollment[]
  assignments     TeacherSubjectAssignment[]
  timetables      Timetable[]
  exams           Exam[]
  attendance_summaries AttendanceSummary[]
  batch_semesters BatchSemester[]
  topic_coverage  TopicCoverage[]

  @@unique([name, academic_year])
  @@map("academic_periods")
}

model BatchSemester {
  batch_semester_id BigInt         @id @default(autoincrement()) @map("batch_semester_id")
  batch_id          BigInt
  period_id         BigInt
  semester_number   Int
  status            String?        @default("ACTIVE") // ACTIVE, COMPLETED
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  batch             Batch          @relation(fields: [batch_id], references: [batch_id])
  period            AcademicPeriod @relation(fields: [period_id], references: [period_id])

  @@unique([batch_id, period_id])
  @@index([batch_id])
  @@index([period_id])
  @@map("batch_semesters")
}

model SyllabusModule {
  module_id      BigInt           @id @default(autoincrement()) @map("module_id")
  subject_id     BigInt           @map("subject_id")
  module_number  Int              @map("module_number")
  module_name    String           @map("module_name")
  description    String?          @db.Text @map("description")
  created_at     DateTime         @default(now()) @map("created_at")
  updated_at     DateTime         @updatedAt @map("updated_at")

  subject        Subject          @relation(fields: [subject_id], references: [subject_id], onDelete: Cascade)
  topics         SyllabusTopic[]
  resources      SyllabusResource[]
  questions      ModuleQuestion[]
  practice_results ModulePracticeResult[]

  @@unique([subject_id, module_number])
  @@index([subject_id])
  @@map("syllabus_modules")
}

model SyllabusTopic {
  topic_id         BigInt           @id @default(autoincrement()) @map("topic_id")
  module_id        BigInt           @map("module_id")
  topic_number     Int              @map("topic_number")
  topic_name       String           @map("topic_name")
  description      String?          @db.Text @map("description")
  content_ai       String?          @db.Text @map("content_ai")
  created_at       DateTime         @default(now()) @map("created_at")
  updated_at       DateTime         @updatedAt @map("updated_at")

  module           SyllabusModule   @relation(fields: [module_id], references: [module_id], onDelete: Cascade)
  resources        SyllabusResource[]
  coverage_records TopicCoverage[]

  @@unique([module_id, topic_number])
  @@index([module_id])
  @@map("syllabus_topics")
}

model SyllabusResource {
  resource_id     BigInt          @id @default(autoincrement()) @map("resource_id")
  module_id       BigInt?         @map("module_id")
  topic_id        BigInt?         @map("topic_id")
  resource_type   String          @map("resource_type") // YOUTUBE, PDF, PPT, LINK, AI_NOTES
  title           String          @map("title")
  url             String?         @db.Text @map("url")
  content_text    String?         @db.Text @map("content_text")
  resource_order  Int             @default(0) @map("resource_order")
  is_ai_generated Boolean         @default(false) @map("is_ai_generated")
  created_at      DateTime        @default(now()) @map("created_at")
  updated_at      DateTime        @updatedAt @map("updated_at")

  module          SyllabusModule? @relation(fields: [module_id], references: [module_id], onDelete: Cascade)
  topic           SyllabusTopic?  @relation(fields: [topic_id], references: [topic_id], onDelete: Cascade)

  @@index([module_id])
  @@index([topic_id])
  @@map("syllabus_resources")
}

model TopicCoverage {
  coverage_id   BigInt            @id @default(autoincrement()) @map("coverage_id")
  topic_id      BigInt            @map("topic_id")
  session_id    BigInt            @map("session_id")
  teacher_id    BigInt            @map("teacher_id")
  batch_id      BigInt            @map("batch_id")
  section_id    BigInt            @map("section_id")
  period_id     BigInt            @map("period_id")
  covered_at    DateTime          @default(now()) @map("covered_at")
  remarks       String?           @db.Text @map("remarks")
  
  topic         SyllabusTopic     @relation(fields: [topic_id], references: [topic_id])
  session       AttendanceSession @relation(fields: [session_id], references: [session_id])
  teacher       Teacher           @relation(fields: [teacher_id], references: [teacher_id])
  batch         Batch             @relation(fields: [batch_id], references: [batch_id])
  section       Section           @relation(fields: [section_id], references: [section_id])
  period        AcademicPeriod    @relation(fields: [period_id], references: [period_id])

  @@unique([topic_id, section_id, period_id])
  @@index([section_id, period_id])
  @@index([topic_id])
  @@map("topic_coverage")
}

model ModuleQuestion {
  question_id    BigInt         @id @default(autoincrement()) @map("question_id")
  module_id      BigInt         @map("module_id")
  question_text  String         @db.Text @map("question_text")
  options        Json?          @map("options")
  correct_answer String         @map("correct_answer")
  explanation    String?        @db.Text @map("explanation")
  difficulty     String?        @map("difficulty") // EASY, MEDIUM, HARD
  created_at     DateTime       @default(now()) @map("created_at")
  updated_at     DateTime       @updatedAt @map("updated_at")

  module         SyllabusModule @relation(fields: [module_id], references: [module_id], onDelete: Cascade)

  @@index([module_id])
  @@map("module_questions")
}

model ModulePracticeResult {
  result_id       BigInt         @id @default(autoincrement()) @map("result_id")
  student_id      BigInt         @map("student_id")
  module_id       BigInt         @map("module_id")
  score           Float          @map("score")
  total_questions Int            @map("total_questions")
  responses       Json?          @map("responses")
  completed_at    DateTime       @default(now()) @map("completed_at")

  student         Student        @relation(fields: [student_id], references: [student_id])
  module          SyllabusModule @relation(fields: [module_id], references: [module_id], onDelete: Cascade)

  @@index([student_id])
  @@index([module_id])
  @@map("module_practice_results")
}
