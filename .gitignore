.DS_Store
Thumbs.db
*.log
*.pem
.vscode/
.idea/
*.tsbuildinfo

# Environment Files
# ------------------------------------------------------------------------------
.env
.env*
!.env.example

# Next.js / Node.js (authority)
# ------------------------------------------------------------------------------
authority/node_modules/
authority/.next/
authority/out/
authority/build/
authority/coverage/
authority/.pnp
authority/.pnp.*
authority/.yarn/*
!authority/.yarn/patches
!authority/.yarn/plugins
!authority/.yarn/releases
!authority/.yarn/versions
authority/generated/prisma/
authority/next-env.d.ts

# Python / Face Detection (authority_ai_service_backend/face-detection-pipeline)
# ------------------------------------------------------------------------------
authority_ai_service_backend/face-detection-pipeline/venv/
authority_ai_service_backend/face-detection-pipeline/.venv/
authority_ai_service_backend/face-detection-pipeline/env/
authority_ai_service_backend/face-detection-pipeline/__pycache__/
authority_ai_service_backend/face-detection-pipeline/.pytest_cache/
